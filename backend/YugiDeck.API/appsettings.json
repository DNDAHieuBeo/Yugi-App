{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=yugideck.db"
  },
  "JwtSettings": {
    "SecretKey": "YugiDeckSuperSecretKey2026MustBe32CharsLong!",
    "Issuer": "YugiDeckAPI",
