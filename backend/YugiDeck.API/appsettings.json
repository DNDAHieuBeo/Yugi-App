{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=cardvault;Username=cardvault;Password=cardvault_pass"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_MUST_BE_32_CHARS_MINIMUM",
    "Issuer": "CardVaultAPI",
    "Audience": "CardVaultClient",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "YgoApi": {
    "BaseUrl": "https://db.ygoprodeck.com/api/v7/"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FrontendUrl": "http://localhost:4200",
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "your-gmail@gmail.com",
    "SenderName": "CardVault",
    "AppPassword": "FILL_IN_YOUR_GMAIL_APP_PASSWORD"
  },
  "AllowedHosts": "*"
}
